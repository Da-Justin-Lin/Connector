# ============================================================
#  REQUIRED
# ============================================================
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Robinhood Agentic Trading access token.
# Get it: Robinhood app → Agentic Trading tab → Connect Agent → Copy token
# Leave blank if TRADE_MODE=SIGNAL_ONLY (default)
ROBINHOOD_ACCESS_TOKEN=

# ============================================================
#  TRADE MODE (start with SIGNAL_ONLY!)
# ============================================================
# SIGNAL_ONLY       — only send push notifications, never place orders
# PREVIEW_APPROVAL  — submit as preview, you tap approve in Robinhood app
# FULL_AUTO         — submit and execute automatically (only after backtest)
TRADE_MODE=SIGNAL_ONLY

# ============================================================
#  RISK MANAGEMENT
# ============================================================
ACCOUNT_CAPITAL=1000
MAX_RISK_PER_TRADE_PCT=0.01     # 1% of capital risked per trade
MAX_POSITION_PCT=0.20           # single stock max 20% of capital
MAX_DAILY_LOSS_PCT=0.02         # 2% daily loss → stop trading for the day
MAX_DRAWDOWN_PCT=0.10           # 10% peak-to-trough → halt all trading
MIN_RISK_REWARD_RATIO=2.0       # target must be 2× the stop distance
MAX_OPEN_POSITIONS=3
ATR_STOP_MULTIPLIER=2.0

# Fractional shares (Robinhood supports 4-decimal fractional).
# Essential for small accounts trading $300+ stocks.
ALLOW_FRACTIONAL_SHARES=true
MIN_FRACTIONAL_SHARES=0.01

# ============================================================
#  SIGNAL THRESHOLDS
# ============================================================
WATCHLIST=AAPL,MSFT,AMZN,META,GOOGL,TSLA,NVDA,AMD,AVGO,PLTR,SNOW,COIN,CRM,ORCL,SHOP,UBER,ABNB,NFLX,MU
CHECK_INTERVAL_SECONDS=300
MIN_SIGNAL_SCORE=5              # out of 13 possible points (backtested sweet spot)
MIN_VOLUME_RATIO=1.5
MIN_ADX_TRENDING=20
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
MIN_ALERT_CONFIDENCE=MEDIUM     # LOW / MEDIUM / HIGH

# Skip LLM veto (useful for testing / offline)
SKIP_LLM_VETO=false

# ============================================================
#  NOTIFICATIONS
# ============================================================
# Google Chat webhook (recommended for phone push):
#   Space name → Apps & Integrations → Webhooks → Add webhook
GCHAT_WEBHOOK_URL=

# Email fallback (Gmail with app password):
EMAIL_FROM=
EMAIL_TO=
EMAIL_APP_PASSWORD=
