# ============================================================
#  REQUIRED
# ============================================================
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Robinhood Agentic Trading access token.
# Get it: Robinhood app → Agentic Trading tab → Connect Agent → Copy token
# Leave blank if TRADE_MODE=SIGNAL_ONLY (default)
ROBINHOOD_ACCESS_TOKEN=

# ============================================================
#  TRADE MODE (start with SIGNAL_ONLY!)
# ============================================================
# SIGNAL_ONLY       — only send push notifications, never place orders
# PREVIEW_APPROVAL  — submit as preview, you tap approve in Robinhood app
# FULL_AUTO         — submit and execute automatically (only after backtest)
TRADE_MODE=SIGNAL_ONLY

# ============================================================
#  RISK MANAGEMENT
# ============================================================
ACCOUNT_CAPITAL=1000
MAX_RISK_PER_TRADE_PCT=0.03     # 3% risked per trade (sweep sweet spot: beats QQQ, DD ~half the index)
MAX_POSITION_PCT=0.35           # single stock max 35% of capital
MAX_DAILY_LOSS_PCT=0.02         # 2% daily loss → stop trading for the day
MAX_DRAWDOWN_PCT=0.10           # 10% peak-to-trough → halt all trading
MIN_RISK_REWARD_RATIO=2.0       # target must be 2× the stop distance
MAX_OPEN_POSITIONS=6
ATR_STOP_MULTIPLIER=2.0

# Fractional shares (Robinhood supports 4-decimal fractional).
# Essential for small accounts trading $300+ stocks.
ALLOW_FRACTIONAL_SHARES=true
MIN_FRACTIONAL_SHARES=0.01

# ============================================================
#  SHORT-SWING PROFILE (~6-day holds)
#  Grid-searched sweet spot on 2018-2025. Backtested Sharpe 2.59,
#  max drawdown -2.4%, ~104 trades/year on the 25-ticker watchlist.
#  Set MAX_TARGET_R_MULTIPLE=99 and TIME_STOP_DAYS=99 to disable
#  the caps and use the classic long-swing profile instead.
# ============================================================
MAX_TARGET_R_MULTIPLE=3.0
TRAIL_MILESTONE_1=1.0      # → stop to breakeven
TRAIL_MILESTONE_2=2.0      # → stop locked at +1R
TRAIL_MILESTONE_3=3.0      # → stop locked at +2R
TIME_STOP_DAYS=4

# ============================================================
#  SIGNAL THRESHOLDS
# ============================================================
# Leave unset to use the built-in 33-name diversified basket (config.py).
# Only set this to override with your own comma-separated list, e.g.:
# WATCHLIST=AAPL,MSFT,NVDA,LLY,JPM,XOM
CHECK_INTERVAL_SECONDS=300
MIN_SIGNAL_SCORE=5              # out of 13 possible points (backtested sweet spot)
MIN_VOLUME_RATIO=1.5
MIN_ADX_TRENDING=20
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
MIN_ALERT_CONFIDENCE=MEDIUM     # LOW / MEDIUM / HIGH

# Entry-quality filters (backtested 2018-2025 — cut OOS drawdown ~16%→12%,
# lifted profit factor 1.48→1.59 at ~flat return). Set both false for the
# older score-only behavior.
BLOCK_DOWNTREND_ENTRY=true      # never open a long while price < EMA20 < EMA50
REQUIRE_RELATIVE_STRENGTH=true  # long must out-return SPY over RS_LOOKBACK_DAYS
RS_LOOKBACK_DAYS=20             # trailing-return window for relative strength

# Skip LLM veto (useful for testing / offline)
SKIP_LLM_VETO=false

# ============================================================
#  NOTIFICATIONS
# ============================================================
# Google Chat webhook (recommended for phone push):
#   Space name → Apps & Integrations → Webhooks → Add webhook
GCHAT_WEBHOOK_URL=

# Connector web app push (preferred — reliable HTTP, unlike SMTP which times
# out from the agent host). Signals appear on the Connector dashboard /signals
# page. CONNECTOR_API_URL is the site base; CONNECTOR_AGENT_KEY must match the
# api-server's AGENT_INGEST_KEY.
CONNECTOR_API_URL=
CONNECTOR_AGENT_KEY=

# Email fallback (Gmail with app password) — times out on Railway, prefer the
# Connector push above:
EMAIL_FROM=
EMAIL_TO=
EMAIL_APP_PASSWORD=
