# SnapTrade credentials — obtain from https://dashboard.snaptrade.com
# Personal plan: the dashboard provides a pre-provisioned userId + userSecret
# alongside the clientId + consumerKey. All four values are required.
SNAPTRADE_CLIENT_ID=your_snaptrade_client_id_here
SNAPTRADE_CONSUMER_KEY=your_snaptrade_consumer_key_here
SNAPTRADE_USER_ID=your_snaptrade_user_id_here
SNAPTRADE_USER_SECRET=your_snaptrade_user_secret_here

# Finnhub market-data API key — obtain from https://finnhub.io (free tier OK)
# Needed for per-symbol candlestick charts. Leave blank to disable the feature.
FINNHUB_API_KEY=your_finnhub_api_key_here

# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/connector

# Comma-separated allowed CORS origins (add your Railway frontend URL in production)
ALLOWED_ORIGINS=http://localhost:3000

# Google OAuth — obtain from https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Public-facing URLs (no trailing slash)
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# JWT settings
SECRET_KEY=change_me_to_a_long_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
